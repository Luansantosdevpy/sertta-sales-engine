{
    "name":  "sertta-sales-engine-api",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Production-grade modular monolith backend foundation for a multi-tenant SaaS automation platform.",
    "main":  "dist/server.js",
    "scripts":  {
                    "dev":  "concurrently \"npm:dev:api\" \"npm:dev:worker\"",
                    "dev:api":  "tsx watch src/server.ts",
                    "dev:worker":  "tsx watch src/worker.ts",
                    "build":  "rimraf dist \u0026\u0026 tsc -p tsconfig.json",
                    "start":  "node dist/server.js",
                    "start:worker":  "node dist/worker.js",
                    "lint":  "eslint \"src/**/*.{ts,tsx}\"",
                    "lint:fix":  "npm run lint -- --fix",
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "format":  "prettier --write .",
                    "simulate:whatsapp":  "tsx src/tools/simulate-whatsapp-chat.ts"
                },
    "engines":  {
                    "node":  "\u003e=20.0.0"
                },
    "dependencies":  {
                         "bullmq":  "^5.12.0",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.4.5",
                         "express":  "^4.21.2",
                         "express-rate-limit":  "^7.4.1",
                         "helmet":  "^8.0.0",
                         "ioredis":  "^5.4.1",
                         "jsonwebtoken":  "^9.0.2",
                         "mongoose":  "^8.7.3",
                         "pino":  "^9.5.0",
                         "pino-http":  "^10.3.0",
                         "zod":  "^3.23.8"
                     },
    "devDependencies":  {
                            "@types/cors":  "^2.8.17",
                            "@types/express":  "^4.17.21",
                            "@types/jsonwebtoken":  "^9.0.7",
                            "@types/node":  "^22.10.1",
                            "@typescript-eslint/eslint-plugin":  "^8.14.0",
                            "@typescript-eslint/parser":  "^8.14.0",
                            "concurrently":  "^9.1.0",
                            "eslint":  "^8.57.1",
                            "eslint-config-prettier":  "^9.1.0",
                            "prettier":  "^3.4.2",
                            "rimraf":  "^6.0.1",
                            "tsx":  "^4.19.2",
                            "typescript":  "^5.6.3"
                        }
}
