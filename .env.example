NODE_ENV=development
PORT=3000
API_PREFIX=/api
LOG_LEVEL=info

MONGODB_URI=mongodb://mongo:27017/sertta_sales_engine

REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=sertta

JWT_SECRET=change-me-with-32-plus-chars
JWT_ISSUER=sertta-sales-engine
JWT_AUDIENCE=sertta-api
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

IDEMPOTENCY_TTL_SECONDS=1800
WEBHOOK_DEFAULT_SIGNATURE_SECRET=

EXECUTION_LOG_RETENTION_DAYS=45
WEBHOOK_EVENT_RETENTION_DAYS=30
JOB_RECORD_RETENTION_DAYS=30

AI_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=12000
OPENAI_TEMPERATURE=0.2

# Optional: comma-separated queue names for worker specialization
# WORKER_QUEUES=webhook-ingestion,outbound-messages
